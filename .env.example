# ── Runtime environment ───────────────────────────────────────────────────────
# Distinguishes local dev from deployed environments. Set to 'local' here.
# NFR-06: dev/prod are isolated by pixicred-{env}-* naming; local uses MiniStack.
ENVIRONMENT=local

# ── Database ──────────────────────────────────────────────────────────────────
# Local: plain password connection used by the service layer and prisma migrate.
# Non-local: DB_HOST / DB_PORT / DB_NAME / DB_IAM_USER are fetched from Secrets Manager
# at cold start; an RDS IAM auth token is generated via @aws-sdk/rds-signer.
# NFR-08: Never commit a real DATABASE_URL; use Secrets Manager in deployed envs.
DATABASE_URL=postgresql://pixicred:pixicred_local@localhost:5433/pixicred

# ── AWS credentials (local MiniStack only) ────────────────────────────────────
# NFR-08: Real AWS credentials must never appear here. CI/CD uses OIDC.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Local MiniStack endpoint — overrides SDK default to route requests to MiniStack.
# NFR-05: MiniStack emulates SQS, SNS, SES, and EventBridge locally.
AWS_ENDPOINT_URL=http://localhost:4566

# ── Service layer ─────────────────────────────────────────────────────────────
# URL the API Lambda uses to invoke the service Lambda.
# Locally: HTTP to the Express service server started by `local/service-server.ts`.
SERVICE_ENDPOINT=http://localhost:3001

# ── Email ─────────────────────────────────────────────────────────────────────
# FR-EMAIL-06: Sender address for all SES emails.
SES_FROM_EMAIL=no-reply@pixicred.com

# ── SQS queue URLs ────────────────────────────────────────────────────────────
# FR-APP-03: Credit check queue — receives application IDs for async underwriting.
CREDIT_CHECK_QUEUE_URL=http://localhost:4566/000000000000/pixicred-local-credit-check

# FR-NOTIF-02: Notification queue — receives SNS-fanned-out events for email delivery.
NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/pixicred-local-notifications

# FR-STMT-05: Statement generation queue — receives account IDs for scheduled billing runs.
STATEMENT_GEN_QUEUE_URL=http://localhost:4566/000000000000/pixicred-local-statement-gen

# FR-BILL-01: Billing lifecycle queue — receives trigger messages for auto-close/reminder sweeps.
BILLING_LIFECYCLE_QUEUE_URL=http://localhost:4566/000000000000/pixicred-local-billing-lifecycle

# ── SNS topic ─────────────────────────────────────────────────────────────────
# Central event bus. All domain events (TRANSACTION_POSTED, STATEMENT_GENERATED, etc.)
# are published here and fan out to subscriber queues.
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:pixicred-local-events

# ── Auth ──────────────────────────────────────────────────────────────────────
# FR-AUTH-08: JWT signing secret. In deployed envs, fetched from Secrets Manager
# under key JWT_SECRET in pixicred-{env}-secrets. Never hardcode a real secret here.
JWT_SECRET=local-dev-jwt-secret-change-in-production
