# PixiCred bootstrap secrets — local only, never committed
#
# Copy this file to .env.secrets and fill in the Supabase connection pooler URLs.
# bootstrap.sh reads this file to populate Secrets Manager with real DATABASE_URL
# values so the CI pre-deploy-check passes without waiting for the first migrate run.
#
#   cp .env.secrets.example .env.secrets
#   # then edit .env.secrets with real values
#
# Format: KEY=value  (no quotes needed; special characters are safe as-is)

DEV_DATABASE_URL=
PROD_DATABASE_URL=
