# PixiCred bootstrap secrets — local only, never committed
#
# Copy this file to .env.secrets and fill in the Supabase connection URLs.
# bootstrap.sh reads this file to populate Secrets Manager with real values
# so the CI pre-deploy-check passes without waiting for the first migrate run.
#
#   cp .env.secrets.example .env.secrets
#   # then edit .env.secrets with real values
#
# Format: KEY=value  (no quotes needed; special characters are safe as-is)
#
# POOLER  — PgBouncer connection pooler (port 6543). Used by Lambda at runtime.
# DIRECT  — Direct Postgres connection  (port 5432). Used by Prisma migrate only.

DEV_DATABASE_URL_POOLER=
DEV_DATABASE_URL_DIRECT=

PROD_DATABASE_URL_POOLER=
PROD_DATABASE_URL_DIRECT=
